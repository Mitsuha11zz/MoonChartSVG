name = "Mitsuha/MoonChartSVG"

version = "0.1.0"

readme = "README.mbt.md"

repository = "https://gitlink.org.cn/Mitsuha/MoonChartSVG"

license = "Apache-2.0"

keywords = ["chart", "svg", "visualization", "barchart", "linechart", "piechart"]

description = "纯 MoonBit 实现的 SVG 图表生成库，支持柱状图、折线图、饼图、散点图、雷达图、面积图、堆叠柱状图、水平柱状图、环形图共9种图表类型，零依赖，Builder API 设计。"
